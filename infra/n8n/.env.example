# Plano Certo - n8n VPS environment
# Copy to .env on the VPS and fill secrets there. Do not commit real values.

N8N_HOST=automacoes.seudominio.com.br
N8N_PROTOCOL=https
N8N_PORT=5678
WEBHOOK_URL=https://automacoes.seudominio.com.br/
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace_with_long_random_password

N8N_ENCRYPTION_KEY=replace_with_32_plus_char_random_key
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace_with_long_random_password

SUPABASE_URL=https://errbmfumiixmyjiltdtq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=server_only_service_role_key
SUPABASE_PUBLISHABLE_KEY=publishable_key_if_needed_for_read_only_calls

WHATSAPP_VERIFY_TOKEN=same_token_used_in_meta_webhook
WHATSAPP_APP_SECRET=meta_app_secret
WHATSAPP_ACCESS_TOKEN=meta_permanent_or_system_user_token
WHATSAPP_PHONE_NUMBER_ID=meta_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=meta_business_account_id

OPENAI_API_KEY=project_or_service_openai_key
GOOGLE_PLACES_API_KEY=google_maps_platform_places_key
GOOGLE_CUSTOM_SEARCH_API_KEY=optional_custom_search_key
GOOGLE_CUSTOM_SEARCH_CX=optional_custom_search_engine_id

CADDY_EMAIL=admin@seudominio.com.br
